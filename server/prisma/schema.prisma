generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  flatNumber    String?
  phone         String?
  role          String    // resident, admin, committee, staff, security
  societyId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  society       Society   @relation(fields: [societyId], references: [id])
  complaints    Complaint[] @relation("Reporter")
  assignedTo    Complaint[] @relation("AssignedStaff")
  updates       ComplaintUpdate[]
  sentInvitations Invitation[] @relation("InvitationInviter")
  acceptedInvitations Invitation[] @relation("InvitationAcceptedBy")
}

model Society {
  id          String    @id @default(uuid())
  name        String
  address     String?
  status      String    @default("active") // active, suspended
  settings    Json?     // JSON for custom settings like notifications, working hours, etc.
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt @default(now())

  users       User[]
  complaints  Complaint[]
  invitations Invitation[]
}

model Complaint {
  id          String    @id @default(uuid())
  societyId   String
  reporterId  String
  flatNumber  String?
  category    String
  subcategory String?
  priority    String    // critical, high, medium, low
  title       String
  description String
  location    String?
  images      String?   // JSON array of URLs
  status      String    // open, assigned, in_progress, waiting_for_parts, waiting_for_approval, resolved, closed, reopened
  assignedTo  String?
  assignedAt  DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  rating      Int?
  feedback    String?
  internalNote String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  society     Society   @relation(fields: [societyId], references: [id])
  reporter    User      @relation("Reporter", fields: [reporterId], references: [id])
  assignedStaff User?   @relation("AssignedStaff", fields: [assignedTo], references: [id])
  updates     ComplaintUpdate[]
}

model ComplaintUpdate {
  id          String   @id @default(uuid())
  complaintId String
  updatedBy   String
  updateType  String   // status_change, comment, assignment, photo
  content     String?
  photos      String?  // JSON array
  oldStatus   String?
  newStatus   String?
  createdAt   DateTime @default(now())

  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [updatedBy], references: [id])
}

model Invitation {
  id           String   @id @default(uuid())
  token        String   @unique
  email        String
  role         String   // resident, staff, committee, security
  flatNumber   String?
  societyId    String
  invitedBy    String
  expiresAt    DateTime
  accepted     Boolean  @default(false)
  acceptedAt   DateTime?
  createdAt    DateTime @default(now())

  society      Society  @relation(fields: [societyId], references: [id])
  inviter      User     @relation("InvitationInviter", fields: [invitedBy], references: [id])
  acceptedBy   User?    @relation("InvitationAcceptedBy", fields: [acceptedByUserId], references: [id])
  acceptedByUserId String?

  @@index([email])
  @@index([token])
  @@index([societyId])
}
